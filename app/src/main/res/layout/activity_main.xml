<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#050505"
    android:padding="16dp">

    <!-- HEADER -->
    <TextView
        android:id="@+id/statusText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="NEXUS v7.0 ULTIMATE"
        android:textColor="#00ff41"
        android:textSize="18sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="16dp"
        android:background="#1a1a1a"
        android:layout_marginBottom="16dp" />

    <!-- MAIN BUTTONS -->
    <Button
        android:id="@+id/btnStartMLBB"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="▶️ START MLBB RANK"
        android:textColor="#000"
        android:textStyle="bold"
        android:background="#00ff41"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnAutoFarm"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="🌾 AUTO FARMING MODE"
        android:textColor="#000"
        android:textStyle="bold"
        android:background="#00ff41"
        android:layout_marginBottom="8dp" />

    <!-- TROLL VOICE SECTION -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎤 TROLL VOICE CHANGER"
        android:textColor="#ff00ff"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="8dp" />

    <Button
        android:id="@+id/btnTrollCewek"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="🎤 Suara Cewek"
        android:textColor="#ff00ff"
        android:background="#1a0033"
        android:layout_marginBottom="4dp" />

    <Button
        android:id="@+id/btnTrollCowok"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="🎤 Suara Cowok Deep"
        android:textColor="#ff00ff"
        android:background="#1a0033"
        android:layout_marginBottom="4dp" />

    <Button
        android:id="@+id/btnTrollRobot"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="🤖 Suara Robot"
        android:textColor="#ff00ff"
        android:background="#1a0033"
        android:layout_marginBottom="4dp" />

    <Button
        android:id="@+id/btnTrollMonster"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="👹 Suara Monster"
        android:textColor="#ff00ff"
        android:background="#1a0033"
        android:layout_marginBottom="4dp" />

    <Button
        android:id="@+id/btnTrollBebek"
        android:layout_width="match_parent"
        android:layout_height="40dp"
        android:text="🦆 Suara Bebek"
        android:textColor="#ff00ff"
        android:background="#1a0033"
        android:layout_marginBottom="16dp" />

    <!-- STOP BUTTON -->
    <Button
        android:id="@+id/btnStop"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="⛔ EMERGENCY STOP"
        android:textColor="#fff"
        android:textStyle="bold"
        android:background="#ff0044"
        android:layout_marginBottom="16dp" />

    <!-- LOG AREA -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📋 System Log"
        android:textColor="#00ff41"
        android:textSize="12sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="#0a0a0a"
        android:padding="8dp">

        <LinearLayout
            android:id="@+id/logContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical" />

    </ScrollView>

</LinearLayout>
